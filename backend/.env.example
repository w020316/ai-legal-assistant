# ===== AI 法律助手后端环境变量示例 =====
# 复制本文件为 .env 并填写真实值，.env 已被 .gitignore 忽略，绝不入库

# ----- Agnes AI (OpenAI V1 兼容) -----
AGNES_API_KEY=sk-你的agnes密钥
AGNES_BASE_URL=https://agnes-ai.com

# ----- 数据库 -----
DB_USER=lawai
DB_PASSWORD=请修改为强密码
DB_NAME=lawai

# ----- Redis -----
REDIS_PASSWORD=请修改为强密码

# ----- JWT -----
JWT_SECRET=请修改为至少32位的随机字符串
JWT_ACCESS_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=604800000

# ----- 服务 -----
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
